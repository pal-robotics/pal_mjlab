    </link>
    <joint name="pelvis_fixed_joint" type="fixed" dont_collapse="true">
        <origin rpy="0 0 0" xyz="-0.0918000000000001 0 -0.0455" />
        <parent link="base_link" />
        <child link="pelvis_base_link" />
    </joint>
    <link name="pelvis_1_link">
