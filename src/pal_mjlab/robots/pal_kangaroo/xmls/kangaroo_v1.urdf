            </geometry>
            <material name="pal_DarkGrey" />
        </visual>
    </link>
    <joint name="back_handle_fixed_joint" type="fixed" dont_collapse="true">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="base_link" />
        <child link="back_handle" />
    </joint>
    <link name="pelvis_base_link">
